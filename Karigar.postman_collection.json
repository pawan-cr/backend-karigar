{
  "info": {
    "name": "Karigar Backend API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "token", "value": "" },
    { "key": "categoryId", "value": "" },
    { "key": "subCategoryId", "value": "" },
    { "key": "businessId", "value": "" },
    { "key": "reviewId", "value": "" },
    { "key": "notificationId", "value": "" },
    { "key": "bannerId", "value": "" },
    { "key": "cityId", "value": "" },
    { "key": "reportId", "value": "" },
    { "key": "userId", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "exec": [
          "const res = pm.response.json();",
          "if (res.token) { pm.collectionVariables.set('token', res.token); console.log('token saved'); }",
          "if (res.user?._id) pm.collectionVariables.set('userId', res.user._id);",
          "if (res.category?._id) pm.collectionVariables.set('categoryId', res.category._id);",
          "if (res.subCategory?._id) pm.collectionVariables.set('subCategoryId', res.subCategory._id);",
          "if (res.business?._id) pm.collectionVariables.set('businessId', res.business._id);",
          "if (res.review?._id) pm.collectionVariables.set('reviewId', res.review._id);",
          "if (res.notification?._id) pm.collectionVariables.set('notificationId', res.notification._id);",
          "if (res.banner?._id) pm.collectionVariables.set('bannerId', res.banner._id);",
          "if (res.city?._id || res.data?._id) pm.collectionVariables.set('cityId', res.city?._id || res.data?._id);",
          "if (res.data?._id && res.data?.reason) pm.collectionVariables.set('reportId', res.data._id);"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "1. AUTH",
      "item": [
        {
          "name": "Login (Firebase token required)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{firebaseToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"role\": \"admin\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) { pm.collectionVariables.set('token', res.token); console.log('JWT saved:', res.token.substring(0,30)+'...'); }",
                  "if (res.user?._id) pm.collectionVariables.set('userId', res.user._id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Me",
          "request": {
